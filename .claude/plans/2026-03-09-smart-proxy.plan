### Task 5: Add Cache Module вЂ” Core Infrastructure

**Files:**
- Create: `src/cache.rs`

**What to create:**

```rust
use std::collections::hash_map::DefaultHasher;
use std::hash::{Hash, Hasher};
use std::path::PathBuf;
use std::time::{Duration, SystemTime};

/// Default cache TTL in minutes
const DEFAULT_TTL_MINUTES: u64 = 5;

/// Cache directory for output storage
fn cache_dir() -> Option<PathBuf> {
    dirs::data_local_dir().map(|d| d.join("rtk").join("cache"))
}

/// Generate a stable key from command + working directory
fn cache_key(cmd: &str, cwd: &str) -> String {
    let mut hasher = DefaultHasher::new();
    cmd.hash(&mut hasher);
    cwd.hash(&mut hasher);
    format!("{:016x}", hasher.finish())
}

/// Commands that change too frequently to benefit from caching.
const SKIP_CACHE_PREFIXES: &[&str] = &[
    "git status",
    "git diff",
    "git log",
    "git show",
    "git stash",
    "ls",
    "find",
    "grep",
    "cat",
    "head",
    "tail",
    "ps",
    "top",
    "env",
    "date",
    "time",
];

/// Check if a command should be cached
fn should_cache(cmd: &str) -> bool {
    let lower = cmd.to_lowercase();
    !SKIP_CACHE_PREFIXES.iter().any(|p| lower.starts_with(p))
}

/// Load cached output if it exists and is within TTL.
/// Returns Some((cached_output, age_secs)) or None.
pub fn load(cmd: &str, cwd: &str, ttl_minutes: u64) -> Option<(String, u64)> {
    if !should_cache(cmd) {
        return None;
    }

    let dir = cache_dir()?;
    let key = cache_key(cmd, cwd);
    let path = dir.join(&key);

    if !path.exists() {
        return None;
    }

    // Check age
    let metadata = std::fs::metadata(&path).ok()?;
    let modified = metadata.modified().ok()?;
    let age = SystemTime::now().duration_since(modified).ok()?;
    let ttl = Duration::from_secs(ttl_minutes * 60);

    if age > ttl {
        // Expired вЂ” remove stale cache
        let _ = std::fs::remove_file(&path);
        return None;
    }

    let content = std::fs::read_to_string(&path).ok()?;
    Some((content, age.as_secs()))
}

/// Store output in cache.
pub fn store(cmd: &str, cwd: &str, output: &str) {
    if !should_cache(cmd) {
        return;
    }

    if let Some(dir) = cache_dir() {
        let key = cache_key(cmd, cwd);
        let _ = std::fs::create_dir_all(&dir);
        let _ = std::fs::write(dir.join(&key), output);
    }
}

/// Compute diff between cached and current output.
/// Returns a compact summary of changes.
pub fn diff_output(cached: &str, current: &str) -> String {
    if cached == current {
        return "(no changes)".to_string();
    }

    let prev_lines: Vec<&str> = cached.lines().collect();
    let curr_lines: Vec<&str> = current.lines().collect();

    let prev_set: std::collections::HashSet<&str> = prev_lines.iter().copied().collect();
    let curr_set: std::collections::HashSet<&str> = curr_lines.iter().copied().collect();

    let removed: Vec<&&str> = prev_lines
        .iter()
        .filter(|l| !l.trim().is_empty() && !curr_set.contains(**l))
        .collect();

    let added: Vec<&&str> = curr_lines
        .iter()
        .filter(|l| !l.trim().is_empty() && !prev_set.contains(**l))
        .collect();

    if removed.is_empty() && added.is_empty() {
        return "(no meaningful changes)".to_string();
    }

    let mut result = Vec::new();

    if !removed.is_empty() {
        result.push(format!("--- Resolved ({}) ---", removed.len()));
        for line in removed.iter().take(20) {
            result.push(format!("  {}", line));
        }
        if removed.len() > 20 {
            result.push(format!("  ... ({} more)", removed.len() - 20));
        }
    }

    if !added.is_empty() {
        result.push(format!("--- New ({}) ---", added.len()));
        for line in added.iter().take(30) {
            result.push(format!("  {}", line));
        }
        if added.len() > 30 {
            result.push(format!("  ... ({} more)", added.len() - 30));
        }
    }

    result.join("\n")
}

/// Read cache TTL from config or env var.
/// Priority: RTK_CACHE_TTL env > config.toml [cache] ttl_minutes > default (5)
pub fn get_ttl_minutes() -> u64 {
    if let Ok(val) = std::env::var("RTK_CACHE_TTL") {
        if let Ok(mins) = val.parse::<u64>() {
            return mins;
        }
    }
    // Config file check would go here when CacheConfig is added
    DEFAULT_TTL_MINUTES
}

/// Clear all cache entries
pub fn clear() -> std::io::Result<()> {
    if let Some(dir) = cache_dir() {
        if dir.exists() {
            std::fs::remove_dir_all(&dir)?;
        }
    }
    Ok(())
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cache_key_deterministic() {
        let a = cache_key("cargo test", "/projects/rtk");
        let b = cache_key("cargo test", "/projects/rtk");
        assert_eq!(a, b);
    }

    #[test]
    fn test_cache_key_varies_by_cwd() {
        let a = cache_key("cargo test", "/projects/rtk");
        let b = cache_key("cargo test", "/projects/other");
        assert_ne!(a, b);
    }

    #[test]
    fn test_should_cache_build() {
        assert!(should_cache("cargo build"));
        assert!(should_cache("pnpm build"));
        assert!(should_cache("npm run build"));
        assert!(should_cache("cargo test"));
        assert!(should_cache("go test ./..."));
    }

    #[test]
    fn test_should_not_cache_volatile() {
        assert!(!should_cache("git status"));
        assert!(!should_cache("git diff"));
        assert!(!should_cache("git log --oneline"));
        assert!(!should_cache("ls -la"));
        assert!(!should_cache("find . -name '*.rs'"));
    }

    #[test]
    fn test_diff_identical() {
        let diff = diff_output("hello\nworld", "hello\nworld");
        assert!(diff.contains("no changes"));
    }

    #[test]
    fn test_diff_added() {
        let diff = diff_output("test_a ok", "test_a ok\ntest_b ok");
        assert!(diff.contains("New (1)"));
        assert!(diff.contains("test_b"));
    }

    #[test]
    fn test_diff_removed() {
        let diff = diff_output("test_a FAIL\ntest_b ok", "test_b ok");
        assert!(diff.contains("Resolved (1)"));
        assert!(diff.contains("FAIL"));
    }

    #[test]
    fn test_get_ttl_default() {
        // Without env var set, should return default
        let ttl = DEFAULT_TTL_MINUTES;
        assert_eq!(ttl, 5);
    }
}
```

